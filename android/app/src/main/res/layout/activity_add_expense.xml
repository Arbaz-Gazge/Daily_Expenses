<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/widget_bg"
    android:layout_margin="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quick Add Expense"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/editAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount (₹ 0.00)"
        android:inputType="numberDecimal"
        android:textColorHint="#94a3b8"
        android:textColor="#ffffff"
        android:background="@drawable/input_bg"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/editDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="What did you buy?"
        android:inputType="text"
        android:textColorHint="#94a3b8"
        android:textColor="#ffffff"
        android:background="@drawable/input_bg"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CATEGORY"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#94a3b8"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="4dp" />

    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_bg"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PAYMENT MODE"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#94a3b8"
        android:layout_marginBottom="4dp"
        android:layout_marginStart="4dp" />

    <Spinner
        android:id="@+id/spinnerPaymentMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/input_bg"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/editRemark"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Add a remark (Optional)"
        android:inputType="text"
        android:textColorHint="#94a3b8"
        android:textColor="#ffffff"
        android:background="@drawable/input_bg"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textAllCaps="false"
            android:backgroundTint="#ef4444"
            android:textColor="#ffffff"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Add Expense"
            android:textAllCaps="false"
            android:backgroundTint="#20e3b2"
            android:textColor="#0f172a"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
